# Docker-published host ports.
# These values control only localhost access from the developer machine.
# Containers still communicate over Docker service names and stable container ports
# such as postgres:5432, redis:6379, api:4000, and alloy:4318.
# Override these when local services or other containers already use the defaults.
API_HOST_PORT=4000
WEB_HOST_PORT=3001
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
LOKI_HOST_PORT=3100
TEMPO_HOST_PORT=3200
ALLOY_HOST_PORT=12345
ALLOY_OTLP_GRPC_HOST_PORT=4317
ALLOY_OTLP_HTTP_HOST_PORT=4318
CADVISOR_HOST_PORT=8081

# API-only local development defaults.
# If you override POSTGRES_HOST_PORT or REDIS_HOST_PORT for Docker, update the
# localhost ports below when running the API or e2e tests directly on the host.
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://food_delivery:food_delivery@localhost:5432/food_delivery?schema=public"
TEST_DATABASE_URL="postgresql://food_delivery:food_delivery@localhost:5432/food_delivery_test?schema=public"
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
POSTGRES_POOL_MAX=10
JWT_ACCESS_TOKEN_SECRET=local-stack-access-secret-change-me
JWT_REFRESH_TOKEN_SECRET=local-stack-refresh-secret-change-me
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800
PAYMENT_SIM_MIN_LATENCY_MS=75
PAYMENT_SIM_MAX_LATENCY_MS=350
LOG_LEVEL=info
OTEL_SERVICE_NAME=food-delivery-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
