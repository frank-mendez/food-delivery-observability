{
  "uid": "food-delivery-infrastructure",
  "title": "Food Delivery Infrastructure",
  "tags": ["food-delivery", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Container CPU",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=~\"food-delivery-.*\"}[1m])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "cores" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 2,
      "title": "Container Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_usage_bytes{name=~\"food-delivery-.*\"}) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 3,
      "title": "PostgreSQL Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "food_delivery_database_connection_status",
          "legendFormat": "postgres"
        }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bool" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Redis Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "food_delivery_redis_connection_status",
          "legendFormat": "redis"
        }
      ],
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bool" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Database Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "food_delivery_database_connection_pool_connections",
          "legendFormat": "{{state}}"
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 6,
      "title": "Redis Operation Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(food_delivery_redis_operation_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}} p95"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 7,
      "title": "Node Event Loop Lag",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "food_delivery_nodejs_eventloop_lag_seconds",
          "legendFormat": "event loop lag"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    }
  ]
}
