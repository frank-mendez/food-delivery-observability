{
  "uid": "food-delivery-orders",
  "title": "Food Delivery Orders",
  "tags": ["food-delivery", "orders"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "title": "Orders Created",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(food_delivery_orders_created_total[1m]))",
          "legendFormat": "created/sec"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 2,
      "title": "Orders Failed",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(food_delivery_failed_order_creation_total[1m]))",
          "legendFormat": "failed/sec"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 3,
      "title": "Average Order Value",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "food_delivery_average_order_value_dollars",
          "legendFormat": "average"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Order Creation Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(food_delivery_order_creation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum(rate(food_delivery_order_creation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    },
    {
      "id": 5,
      "title": "Order Value Distribution",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(food_delivery_order_value_dollars_bucket[5m])) by (le)",
          "legendFormat": "{{le}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } }
    }
  ]
}
