{
  "name": "food-delivery-observability",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:api": "pnpm --filter @food-delivery/api dev",
    "dev:web": "pnpm --filter @food-delivery/web dev",
    "build": "pnpm build:api && pnpm build:web",
    "build:api": "pnpm --filter @food-delivery/api build",
    "build:web": "pnpm --filter @food-delivery/web build",
    "test": "pnpm test:api && pnpm test:web",
    "test:api": "pnpm --filter @food-delivery/api test",
    "test:web": "pnpm --filter @food-delivery/web test",
    "test:cov": "pnpm --filter @food-delivery/api test:cov",
    "test:cov:web": "pnpm --filter @food-delivery/web test",
    "test:e2e": "pnpm --filter @food-delivery/api test:e2e",
    "lint": "pnpm lint:api && pnpm lint:web",
    "lint:api": "pnpm --filter @food-delivery/api lint",
    "lint:web": "pnpm --filter @food-delivery/web lint",
    "typecheck": "pnpm typecheck:api && pnpm typecheck:web",
    "typecheck:api": "pnpm --filter @food-delivery/api typecheck",
    "typecheck:web": "pnpm --filter @food-delivery/web typecheck",
    "format": "pnpm --filter @food-delivery/api format",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "storybook": "pnpm --filter @food-delivery/web storybook",
    "build-storybook": "pnpm --filter @food-delivery/web build-storybook",
    "playwright": "pnpm --filter @food-delivery/web playwright",
    "prisma:generate": "pnpm --filter @food-delivery/api prisma:generate",
    "prisma:migrate": "pnpm --filter @food-delivery/api prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter @food-delivery/api prisma:migrate:deploy",
    "prisma:seed": "pnpm --filter @food-delivery/api prisma:seed",
    "docker:app": "docker compose up --build -d api web",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f"
  }
}
