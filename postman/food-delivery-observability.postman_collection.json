    {
      "name": "03 Restaurants",
      "item": [
        {
          "name": "GET /restaurants",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const restaurants = pm.response.json();",
                  "const restaurant = restaurants.find((item) => Array.isArray(item.menuItems) && item.menuItems.length > 0);",
                  "if (restaurant) {",
                  "  pm.collectionVariables.set('restaurantId', restaurant.id);",
                  "  pm.collectionVariables.set('menuItemId', restaurant.menuItems[0].id);",
                  "}"
                ]
